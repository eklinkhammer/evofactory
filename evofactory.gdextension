[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]
macos.debug = "res://rust/target/debug/libevofactory.dylib"
macos.release = "res://rust/target/release/libevofactory.dylib"
linux.debug.x86_64 = "res://rust/target/debug/libevofactory.so"
linux.release.x86_64 = "res://rust/target/release/libevofactory.so"
windows.debug.x86_64 = "res://rust/target/debug/evofactory.dll"
windows.release.x86_64 = "res://rust/target/release/evofactory.dll"
